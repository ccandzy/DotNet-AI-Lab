<Window x:Class="AiChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AiChatClient"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AiChatClient.Models"
        Title="MainWindow"
        Width="800"
        Height="450"
        mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left panel: conversations -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Margin="0,0,8,0" Padding="8" Background="#FAFAFA" CornerRadius="8">
            <DockPanel LastChildFill="True">
                <Button Content="新会话" Command="{Binding NewConversationCommand}" Height="30" Margin="0,0,0,8" DockPanel.Dock="Top" />
                <StackPanel>
                    <ListBox ItemsSource="{Binding Conversations}" SelectedItem="{Binding CurrentConversation, Mode=TwoWay}" DisplayMemberPath="Title" Height="400" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                        <Button Content="重命名" Width="80" Margin="0,0,8,0" Click="RenameConversation_Click" />
                        <Button Content="删除" Width="80" Command="{Binding DeleteConversationCommand}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" Margin="0,0,0,8" Padding="12" Background="#F2F2F2" CornerRadius="8">
            <DockPanel>
                <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Text="AI Chat" />

                <Button Width="72" Height="30" Command="{Binding ClearCommand}" Content="清空" DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Padding="8" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8">
            <ListBox x:Name="MessagesListBox" Background="Transparent" BorderThickness="0" ItemsSource="{Binding Messages}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ChatMessage}">
                        <Grid Margin="0,4">
                            <Border x:Name="Bubble"
                                    MaxWidth="580"
                                    Padding="10"
                                    HorizontalAlignment="Left"
                                    Background="#F3F4F6"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               HorizontalAlignment="Right"
                                               FontSize="10"
                                               Foreground="Gray"
                                               Text="{Binding Timestamp, StringFormat=HH:mm:ss}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Bubble" Property="Background" Value="#DCF3FF" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox" Grid.Column="0"
                     MinHeight="70"
                     MaxHeight="140"
                     AcceptsReturn="True"
                      Text="{Binding CurrentInput, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Bottom">
                <Button Width="90"
                        Height="34"
                        Command="{Binding SendCommand}"
                        Content="发送" />
                <Button Width="90"
                        Height="34"
                        Margin="0,6,0,0"
                        Command="{Binding StopCommand}"
                        Content="停止"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Margin="0,6,0,0"
                           HorizontalAlignment="Center"
                           Foreground="Gray"
                           Text="思考中..."
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
